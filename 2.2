-- [HÀM TẠO ESP CHUẨN XÁC VỊ TRÍ]
local function CreateVisual(obj, color, label)
    if not obj or not obj.Parent or obj:FindFirstChild("Tamdz_Visuals") then return end
    
    local container = Instance.new("Folder")
    container.Name = "Tamdz_Visuals"
    container.Parent = obj

    local targetPart = nil
    if obj:IsA("BasePart") then
        targetPart = obj
    elseif obj:IsA("Model") then
        targetPart = obj.PrimaryPart or obj:FindFirstChildOfClass("BasePart")
    end
    
    if not targetPart then return end

    local bill = Instance.new("BillboardGui", container)
    bill.Size = UDim2.new(0, 180, 0, 50)
    bill.AlwaysOnTop = true
    bill.StudsOffset = Vector3.new(0, 1.5, 0)
    bill.Adornee = targetPart

    local txt = Instance.new("TextLabel", bill)
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.TextColor3 = color
    txt.TextSize = 14
    txt.Font = Enum.Font.SourceSansBold
    txt.TextStrokeTransparency = 0

    local att1 = Instance.new("Attachment", targetPart)
    local beam = Instance.new("Beam", container)
    beam.Attachment1 = att1
    beam.Color = ColorSequence.new(color)
    beam.Width0, beam.Width1 = 0.1, 0.1
    beam.LightEmission, beam.FaceCamera = 1, true

    task.spawn(function()
        while obj and obj.Parent and container.Parent and targetPart and targetPart.Parent do
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root and _G.Tracers then
                local att0 = root:FindFirstChild("Tamdz_Att") or Instance.new("Attachment", root)
                att0.Name = "Tamdz_Att"
                beam.Attachment0 = att0
                beam.Enabled = true
                local dist = math.floor((root.Position - targetPart.Position).Magnitude)
                txt.Text = label .. "\n[" .. dist .. "m]"
            else
                beam.Enabled = false
                txt.Text = label
            end
            task.wait(0.2)
        end
    end)
end

-- [HÀM ESP NGƯỜI CHƠI]
local function ApplyPlayerESP(plr)
    if plr == LocalPlayer then return end
    
    local function setupChar(char)
        if not char then return end
        if char:FindFirstChild("Tamdz_PlayerContainer") then
            char.Tamdz_PlayerContainer:Destroy()
        end

        local container = Instance.new("Folder")
        container.Name = "Tamdz_PlayerContainer"
        container.Parent = char

        local hl = Instance.new("Highlight")
        hl.Name = "Tamdz_PlayerHL"
        hl.Adornee = char
        hl.FillColor = Color3.fromRGB(0, 170, 255)
        hl.OutlineColor = Color3.fromRGB(255, 255, 255)
        hl.FillTransparency = 0.5
        hl.OutlineTransparency = 0
        hl.Parent = container

        local rootPart = char:WaitForChild("HumanoidRootPart", 5)
        if rootPart then
            local bill = Instance.new("BillboardGui")
            bill.Name = "Tamdz_PlayerTag"
            bill.Size = UDim2.new(0, 180, 0, 50)
            bill.StudsOffset = Vector3.new(0, 3, 0)
            bill.AlwaysOnTop = true
            bill.Adornee = rootPart
            bill.Parent = container

            local txt = Instance.new("TextLabel")
            txt.Size = UDim2.new(1, 0, 1, 0)
            txt.BackgroundTransparency = 1
            txt.TextColor3 = Color3.fromRGB(0, 255, 255)
            txt.TextSize = 14
            txt.Font = Enum.Font.SourceSansBold
            txt.TextStrokeTransparency = 0
            txt.Parent = bill

            task.spawn(function()
                while container and container.Parent and char and char.Parent do
                    if _G.ESP_Players then
                        hl.Enabled = true
                        bill.Enabled = true
                        local lChar = LocalPlayer.Character
                        local lRoot = lChar and lChar:FindFirstChild("HumanoidRootPart")
                        if lRoot and rootPart then
                            local dist = math.floor((lRoot.Position - rootPart.Position).Magnitude)
                            txt.Text = plr.Name .. "\n[" .. dist .. "m]"
                        else
                            txt.Text = plr.Name
                        end
                    else
                        hl.Enabled = false
                        bill.Enabled = false
                    end
                    task.wait(0.2)
                end
            end)
        end
    end

    if plr.Character then
        setupChar(plr.Character)
    end
    plr.CharacterAdded:Connect(setupChar)
end

for _, p in pairs(Players:GetPlayers()) do
    ApplyPlayerESP(p)
end
Players.PlayerAdded:Connect(ApplyPlayerESP)

