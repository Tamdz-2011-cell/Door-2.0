-- [HỆ THỐNG CẢNH BÁO QUÁI & TỰ ĐỘNG CHẠY VÀO TỦ]
workspace.ChildAdded:Connect(function(v)
    local name = v.Name
    if name:find("Moving") or name == "FigureTag" or name == "SeekMoving" or name == "RushMoving" or name == "AmbushMoving" or name == "Eyes" or name == "Lookman" then
        task.spawn(function()
            task.wait(0.05)
            if _G.AntiEntity then
                Rayfield:Notify({
                    Title = "⚠️ CẢNH BÁO QUÁI XUẤT HIỆN!",
                    Content = name .. " vừa xuất hiện!",
                    Duration = 4,
                })
            end

            if _G.AutoHide and (name == "RushMoving" or name == "AmbushMoving") then
                local char = LocalPlayer.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                local humanoid = char and char:FindFirstChildOfClass("Humanoid")
                
                if root and humanoid then
                    local closestHide = nil
                    local shortestDist = math.huge

                    for _, obj in pairs(workspace:GetDescendants()) do
                        if (obj.Name == "Closet" or obj.Name == "Wardrobe" or obj.Name:find("Hide")) then
                            local prompt = obj:FindFirstChildOfClass("ProximityPrompt") or obj:FindFirstChild("Prompt", true)
                            local targetPart = obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")) or (obj:IsA("BasePart") and obj)
                            
                            if prompt and targetPart then
                                local dist = (root.Position - targetPart.Position).Magnitude
                                if dist < shortestDist then
                                    shortestDist = dist
                                    closestHide = {Part = targetPart, Prompt = prompt}
                                end
                            end
                        end
                    end

                    if closestHide then
                        humanoid:MoveTo(closestHide.Part.Position)
                        
                        task.spawn(function()
                            local timeout = 0
                            while timeout < 6 do
                                if (root.Position - closestHide.Part.Position).Magnitude < 6 then
                                    closestHide.Prompt.HoldDuration = 0
                                    fireproximityprompt(closestHide.Prompt)
                                    break
                                end
                                timeout = timeout + 0.1
                                task.wait(0.1)
                            end
                        end)
                    end
                end
            end
        end)
    end
end)

-- [VÒNG LẶP QUÉT VẬT THỂ & SMART EYES / LOOKMAN]
task.spawn(function()
    while task.wait(0.15) do
        pcall(function()
            local char = LocalPlayer.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            local root = char.HumanoidRootPart

            for _, v in pairs(workspace:GetDescendants()) do
                if _G.AutoSmartEyes then
                    if v.Name == "Eyes" then
                        local part = v:IsA("BasePart") and v or (v:IsA("Model") and (v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart")))
                        if part and (root.Position - part.Position).Magnitude < 50 then
                            Camera.CFrame = CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + Vector3.new(0, -25, 0))
                        end
                    elseif v.Name == "Lookman" then
                        local part = v:IsA("BasePart") and v or (v:IsA("Model") and (v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart")))
                        if part and (root.Position - part.Position).Magnitude < 50 then
                            Camera.CFrame = CFrame.new(Camera.CFrame.Position, part.Position)
                        end
                    end
                end

                if (v.Name == "KeyObtain" or (v.Name:find("Key") and v:IsA("Model") and not v.Name:find("Typewriter"))) then
                    if _G.ESP_Keys then CreateVisual(v, Color3.fromRGB(255, 255, 0), "KEY") end
                    if _G.AutoKey and (root.Position - (v:IsA("BasePart") and v.Position or v:GetModelCFrame().p)).Magnitude <= 40 then
                        local p = v:FindFirstChildOfClass("ProximityPrompt") or v.Parent:FindFirstChildOfClass("ProximityPrompt")
                        if p then p.HoldDuration = 0; fireproximityprompt(p) end
                    end
                end

                if v.Name == "Door" and v:IsA("Model") and (v:FindFirstChild("Sign") or v:FindFirstChild("Number")) then
                    if _G.ESP_Doors then CreateVisual(v, Color3.fromRGB(0, 255, 255), "DOOR") end
                    if _G.AutoOpen and (root.Position - v:GetModelCFrame().p).Magnitude <= 15 then
                        local p = v:FindFirstChildOfClass("ProximityPrompt") or v:FindFirstChild("Lock", true) and v.Lock:FindFirstChildOfClass("ProximityPrompt")
                        if p then p.HoldDuration = 0; fireproximityprompt(p) end
                    end
                end

                if v.Name:find("Lever") or v.Name:find("Switch") or v.Name:find("Breaker") or v.Name:find("Button") then
                    local hasPrompt = v:FindFirstChildOfClass("ProximityPrompt") or (v.Parent and v.Parent:FindFirstChildOfClass("ProximityPrompt"))
                    if hasPrompt or v:IsA("Model") or v:IsA("BasePart") then
                        if _G.ESP_Levers then 
                            CreateVisual(v, Color3.fromRGB(255, 128, 0), "LEVER / SWITCH")
                        end
                    end
                end

                if v.Name == "LiveHintBook" then
                    local hasPrompt = v:FindFirstChildOfClass("ProximityPrompt") or (v.Parent and v.Parent:FindFirstChildOfClass("ProximityPrompt"))
                    if hasPrompt then
                        if _G.ESP_Books then
                            CreateVisual(v, Color3.fromRGB(170, 0, 255), "PUZZLE BOOK")
                        end
                        if _G.AutoBook and (root.Position - (v:IsA("BasePart") and v.Position or v:GetModelCFrame().p)).Magnitude <= 40 then
                            local p = hasPrompt
                            if p then p.HoldDuration = 0; fireproximityprompt(p) end
                        end
                    end
                end

                if v.Name == "BreakerPolePickup" or v.Name:find("BreakerPole") then
                    local hasPrompt = v:FindFirstChildOfClass("ProximityPrompt") or (v.Parent and v.Parent:FindFirstChildOfClass("ProximityPrompt"))
                    if hasPrompt then
                        if _G.ESP_Breakers then
                            CreateVisual(v, Color3.fromRGB(0, 255, 0), "BREAKER POLE")
                        end
                        if _G.AutoBreaker and (root.Position - (v:IsA("BasePart") and v.Position or v:GetModelCFrame().p)).Magnitude <= 40 then
                            local p = hasPrompt
                            if p then p.HoldDuration = 0; fireproximityprompt(p) end
                        end
                    end
                end

                if v.Name:find("Moving") or v.Name == "FigureTag" or v.Name == "SeekMoving" or v.Name == "RushMoving" or v.Name == "AmbushMoving" or v.Name == "Eyes" or v.Name == "Lookman" then
                    if _G.ESP_Boss then 
                        CreateVisual(v, Color3.fromRGB(255, 0, 0), "ENTITY: " .. v.Name) 
                    end
                end
            end
        end)
    end
end)

-- [XỬ LÝ WALKSPEED CHỐNG GIẬT & NOCLIP / FULLBRIGHT]
RunService.Stepped:Connect(function()
    local char = LocalPlayer.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        
        if humanoid and rootPart then
            if _G.SpeedEnabled then
                humanoid.WalkSpeed = 16
                if humanoid.MoveDirection.Magnitude > 0 then
                    rootPart.CFrame = rootPart.CFrame + (humanoid.MoveDirection * (_G.WalkSpeedValue - 16) * 0.05)
                end
            end
        end

        if _G.Noclip then
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end
    if _G.Fullbright then Lighting.Ambient = Color3.fromRGB(255, 255, 255) end
end)
